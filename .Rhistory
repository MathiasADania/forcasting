filter(key == "International trafik i alt") %>%
gg_tsdisplay(difference(log(x1000_passagerer), lag = 4),
plot_type = "partial", lag_max = 24) +
labs(title = "ACF/PACF – sæsondiff (D=1, lag=4) – International")
