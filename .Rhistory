bind_rows(
augment(fit_ets) %>% filter(.model=="Auto") %>%
features(.innov, ljung_box, lag=8, dof=0) %>% mutate(data="inkl."),
augment(fit_ets_corona) %>% filter(.model=="Auto") %>%
features(.innov, ljung_box, lag=8, dof=0) %>% mutate(data="uden")
) %>% select(key, data, lb_stat, lb_pvalue) %>% print()
