cat("=== ARIMA LJUNG-BOX (alle 4) ===\n")
bind_rows(
augment(fit_arima) %>% filter(.model=="Auto") %>%
features(.innov, ljung_box, lag=8, dof=dof_int) %>%
filter(key=="International trafik i alt") %>% mutate(data="inkl."),
augment(fit_arima) %>% filter(.model=="Auto") %>%
features(.innov, ljung_box, lag=8, dof=dof_osb) %>%
filter(key=="Over Storebælt") %>% mutate(data="inkl."),
augment(fit_arima_corona) %>% filter(.model=="Auto") %>%
features(.innov, ljung_box, lag=8, dof=dof_corona_int) %>%
filter(key=="International trafik i alt") %>% mutate(data="uden"),
augment(fit_arima_corona) %>% filter(.model=="Auto") %>%
features(.innov, ljung_box, lag=8, dof=dof_corona_osb) %>%
filter(key=="Over Storebælt") %>% mutate(data="uden")
) %>% select(key, data, lb_stat, lb_pvalue) %>% print()
# === 11. OPTIMAL ARIMA GLANCE ===
cat("=== OPTIMAL ARIMA INKL. ===\n")
glance(fit_arima_optimal) %>% arrange(key, AICc) %>%
select(key, .model, AICc) %>% print()
cat("=== OPTIMAL ARIMA UDEN ===\n")
glance(fit_arima_optimal_corona) %>% arrange(key, AICc) %>%
select(key, .model, AICc) %>% print()
# === 12. TSCV ACCURACY ===
cat("=== TSCV ACCURACY ===\n")
bind_rows(resultat_tscv, resultat_tscv_corona) %>%
select(data, .model, key, RMSE, MASE) %>%
arrange(data, key, RMSE) %>% print()
# === 13. FORECAST PUNKTESTIMATER ===
cat("=== FORECAST INKL. ===\n")
jernbanedata %>%
model(ARIMA=ARIMA(log(x1000_passagerer)), ETS=ETS(log(x1000_passagerer))) %>%
forecast(h=4) %>%
select(key, .model, kvartal, .mean) %>%
arrange(key, .model, kvartal) %>% print()
jernbanedata %>% as_tibble() %>% group_by(key) %>%
summarise(mean=round(mean(x1000_passagerer,na.rm=T),0),
sd=round(sd(x1000_passagerer,na.rm=T),0),
min=round(min(x1000_passagerer,na.rm=T),0),
max=round(max(x1000_passagerer,na.rm=T),0)) %>% print()
